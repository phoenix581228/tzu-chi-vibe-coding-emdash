# Secrets
.env
.env.local
.env.*.local

# Built artefacts
**/dist/
**/.astro/
**/build/
**/.output/

# Wrangler / miniflare local state (regenerated on `pnpm dev` / `pnpm deploy`)
**/.wrangler/

# Dependencies
**/node_modules/
.pnpm-store/

# Local databases (regenerated by `pnpm bootstrap`)
**/data.db
**/data.db-journal
**/data.db-shm
**/data.db-wal
**/*.sqlite
**/*.sqlite3

# Astro / EmDash generated files (regenerated on `pnpm dev`)
**/emdash-env.d.ts
**/.astro-cache/
**/worker-configuration.d.ts.bak

# OS junk
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*~

# Logs / debug
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cloned EmDash upstream (kept locally for reference, not part of this repo)
/source/

# Old Python venv left over in this folder
/bin/
/include/
/lib/
/pyvenv.cfg

# Tool result spillage from earlier sessions
/Gemini_Generated_Image_*.png

# Backup files left over from manual patching
**/*.bak
