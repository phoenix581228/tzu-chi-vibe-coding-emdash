{
  "name": "my-emdash-blog",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "emdash": {
    "label": "Blog",
    "seed": "seed/seed.json"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:cf": "astro build --config astro.config.cloudflare.mjs",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "bootstrap": "emdash init && emdash seed",
    "seed": "emdash seed",
    "deploy": "pnpm build:cf && wrangler deploy",
    "cf:secret": "wrangler secret put EMDASH_ENCRYPTION_KEY",
    "cf:tail": "wrangler tail",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.1",
    "@astrojs/node": "^10.0.0",
    "@astrojs/react": "^5.0.0",
    "@emdash-cms/cloudflare": "^0.9.0",
    "@emdash-cms/plugin-audit-log": "^0.1.2",
    "@local/markdown-marks": "file:./plugins/markdown-marks",
    "astro": "^6.0.1",
    "better-sqlite3": "^12.8.0",
    "emdash": "^0.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260506.1",
    "wrangler": "^4.88.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}