---
/**
 * Bilingual zh / en switcher.
 *
 * Sets a cookie `emdash-lang` and reloads the current page so all
 * server-rendered components pick up the new lang on the next request.
 */
import { getLang, LABELS } from "../utils/lang";

const lang = getLang(Astro);
const t = LABELS[lang];
---

<div class="lang-switcher" role="group" aria-label={t.lang_label}>
	<button
		type="button"
		class="lang-btn"
		data-lang="zh"
		aria-pressed={lang === "zh"}
	>
		{LABELS.zh.lang_zh}
	</button>
	<button
		type="button"
		class="lang-btn"
		data-lang="en"
		aria-pressed={lang === "en"}
	>
		{LABELS.en.lang_en}
	</button>
</div>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>(".lang-btn");

	function setLangCookie(lang: string) {
		const secure = location.protocol === "https:" ? "; Secure" : "";
		// 1 year, site-wide
		document.cookie = `emdash-lang=${lang}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax${secure}`;
	}

	buttons.forEach((btn) => {
		btn.addEventListener("click", () => {
			const target = btn.dataset.lang;
			if (target !== "zh" && target !== "en") return;
			setLangCookie(target);
			// reload preserves URL & query, so the new lang takes effect on the same page
			location.reload();
		});
	});
</script>

<style>
	.lang-switcher {
		display: inline-flex;
		gap: 2px;
		padding: 2px;
		background: var(--color-surface);
		border-radius: var(--radius);
		font-size: var(--font-size-xs);
	}

	.lang-btn {
		appearance: none;
		background: transparent;
		border: none;
		color: var(--color-muted);
		padding: 4px 10px;
		border-radius: calc(var(--radius) - 1px);
		cursor: pointer;
		font-family: inherit;
		font-size: inherit;
		transition: all var(--transition-fast);
	}

	.lang-btn:hover {
		color: var(--color-text-secondary);
	}

	.lang-btn[aria-pressed="true"] {
		background: var(--color-bg);
		color: var(--color-text);
		box-shadow: var(--shadow-btn-active);
	}
</style>
