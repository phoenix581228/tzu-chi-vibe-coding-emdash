---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import { getLang, LABELS } from "../../utils/lang";

const lang = getLang(Astro);
const t = LABELS[lang];

const { entries: lessons, cacheHint } = await getEmDashCollection("lessons", {
	orderBy: { created_at: "asc" },
});

Astro.cache.set(cacheHint);

// Show only lessons that match the visitor's language.
// (Lessons in the other language are still reachable by switching the
// language toggle in the header, which reloads the page.)
const visible = lessons.filter((l) => l.data.lang === lang);
---

<Base title={t.lessons_title} description={t.lessons_desc}>
	<div class="lessons-page">
		<header class="page-header">
			<h1 class="page-title">{t.lessons_title}</h1>
			<p class="page-description">
				{t.lessons_desc}
				<br />
				{t.lessons_dogfood}
			</p>
		</header>

		<section class="lesson-section">
			<ul class="lesson-list">
				{visible.map((l) => (
					<li class="lesson-card">
						<a href={`/lessons/${l.id}`}>
							<span class="phase">{t.lessons_phase} {l.data.phase}</span>
							<h3>{l.data.title}</h3>
							<p>{l.data.summary}</p>
						</a>
					</li>
				))}
			</ul>
		</section>
	</div>
</Base>

<style>
	.lessons-page { max-width: 920px; margin: 0 auto; padding: 2rem 1rem; }
	.page-header { margin-bottom: 3rem; }
	.page-title { font-size: 2.5rem; margin: 0 0 .5rem; }
	.page-description { color: var(--color-text-muted, #666); line-height: 1.6; }
	.lesson-section { margin-bottom: 3rem; }
	.lesson-list { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; }
	.lesson-card a { display: block; padding: 1rem; border: 1px solid var(--color-border, #ddd); border-radius: .5rem; text-decoration: none; color: inherit; }
	.lesson-card a:hover { border-color: currentColor; }
	.phase { display: inline-block; font-size: .75rem; font-weight: 600; padding: .15rem .5rem; border-radius: .25rem; background: var(--color-accent, #f0f0f0); }
	.lesson-card h3 { margin: .5rem 0; font-size: 1.1rem; }
	.lesson-card p { color: var(--color-text-muted, #666); font-size: .9rem; line-height: 1.5; margin: 0; }
</style>
