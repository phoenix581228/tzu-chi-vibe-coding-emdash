# EmDash environment variables
#
# Copy this file to `.env` and fill in real values. The dev server reads
# `.env` on startup; never commit `.env` itself (already gitignored).

# Required: 32-byte (base64) encryption key. Generate with:
#   npx emdash auth secret
# The command prints `EMDASH_ENCRYPTION_KEY=...` — paste the line below.
EMDASH_ENCRYPTION_KEY=

# Optional: public origin for passkey/CSRF when running behind a reverse
# proxy or different host. Leave blank for local dev on http://localhost:4321.
# EMDASH_SITE_URL=https://example.com
